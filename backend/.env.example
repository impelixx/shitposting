# Локальная разработка (без Docker): postgres://user:pass@localhost:5432/blogik?sslmode=disable
# В Docker Compose хост БД — "db": postgres://blogik:blogik@db:5432/blogik?sslmode=disable
DATABASE_URL=postgres://blogik:blogik@localhost:5432/blogik?sslmode=disable

# Минимум 32 символа, случайная строка
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# В Docker Compose хост — "meilisearch"
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=masterKey

# Cloudflare R2 (необязательно для локальной разработки)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=blogik-images
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

PORT=8080
